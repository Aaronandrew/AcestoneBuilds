# ============================================================
# ACESTONE DEVELOPMENT — AWS CREDENTIALS TEMPLATE
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# AWS IAM Credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000

# SES Configuration
SES_FROM_EMAIL=no-reply@yourdomain.com
ADMIN_EMAIL=admin@acestonellc.com

# DynamoDB Table Names
DYNAMODB_LEADS_TABLE=acestone-leads
DYNAMODB_USERS_TABLE=acestone-users

# S3 Bucket
S3_BUCKET_NAME=acestone-uploads

# Server
PORT=5000
